{
  "uid": "dfkv-backend",
  "title": "dfkv — backend (cache nodes + MDS)",
  "tags": ["dfkv", "telemetry", "backend"],
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "type": "query",
        "name": "node",
        "label": "Cache node",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "qryType": 1, "query": "label_values(dfkv_uptime_seconds, instance)", "refId": "A" },
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Cache nodes (dfkv_server — Prometheus pull /metrics)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Cache hit ratio",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "green", "value": 0.8 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(dfkv_cache_hit_total{instance=~\"$node\"}[$__rate_interval])) / clamp_min(sum(rate(dfkv_cache_hit_total{instance=~\"$node\"}[$__rate_interval])) + sum(rate(dfkv_cache_miss_total{instance=~\"$node\"}[$__rate_interval])), 1e-9)", "instant": true }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Cached objects",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        { "refId": "A", "expr": "sum(dfkv_objects{instance=~\"$node\"})", "instant": true }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Used bytes",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "fixed", "fixedColor": "purple" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        { "refId": "A", "expr": "sum(dfkv_used_bytes{instance=~\"$node\"})", "instant": true }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Open connections",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        { "refId": "A", "expr": "sum(dfkv_open_connections{instance=~\"$node\"})", "instant": true }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Cache ops/s (hit / miss / put)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(dfkv_cache_hit_total{instance=~\"$node\"}[$__rate_interval]))", "legendFormat": "hit" },
        { "refId": "B", "expr": "sum(rate(dfkv_cache_miss_total{instance=~\"$node\"}[$__rate_interval]))", "legendFormat": "miss" },
        { "refId": "C", "expr": "sum(rate(dfkv_cache_put_total{instance=~\"$node\"}[$__rate_interval]))", "legendFormat": "put" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Exist checks/s (hit / miss)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(dfkv_exist_hit_total{instance=~\"$node\"}[$__rate_interval]))", "legendFormat": "exist hit" },
        { "refId": "B", "expr": "sum(rate(dfkv_exist_miss_total{instance=~\"$node\"}[$__rate_interval]))", "legendFormat": "exist miss" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Op latency (avg / p99) by op",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 0 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum by (op) (rate(dfkv_op_latency_seconds_sum{instance=~\"$node\"}[$__rate_interval])) / clamp_min(sum by (op) (rate(dfkv_op_latency_seconds_count{instance=~\"$node\"}[$__rate_interval])), 1e-9)", "legendFormat": "avg {{op}}" },
        { "refId": "B", "expr": "histogram_quantile(0.99, sum by (le, op) (rate(dfkv_op_latency_seconds_bucket{instance=~\"$node\"}[$__rate_interval])))", "legendFormat": "p99 {{op}}" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Throughput (bytes/s read / written)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 13 },
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(dfkv_bytes_read_total{instance=~\"$node\"}[$__rate_interval]))", "legendFormat": "read" },
        { "refId": "B", "expr": "sum(rate(dfkv_bytes_written_total{instance=~\"$node\"}[$__rate_interval]))", "legendFormat": "written" }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Evictions (objects/s & bytes/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 13 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [ { "matcher": { "id": "byName", "options": "bytes/s" }, "properties": [ { "id": "unit", "value": "Bps" }, { "id": "custom.axisPlacement", "value": "right" } ] }, { "matcher": { "id": "byName", "options": "objects/s" }, "properties": [ { "id": "unit", "value": "short" } ] } ] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(dfkv_evictions_total{instance=~\"$node\"}[$__rate_interval]))", "legendFormat": "objects/s" },
        { "refId": "B", "expr": "sum(rate(dfkv_evicted_bytes_total{instance=~\"$node\"}[$__rate_interval]))", "legendFormat": "bytes/s" }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Errors/s by op/status",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 13 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum by (op, status) (rate(dfkv_errors_total{instance=~\"$node\"}[$__rate_interval]))", "legendFormat": "{{op}}/{{status}}" }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Capacity: used bytes (per node) & per-disk",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "dfkv_used_bytes{instance=~\"$node\"}", "legendFormat": "{{instance}} used" },
        { "refId": "B", "expr": "dfkv_disk_used_bytes{instance=~\"$node\"}", "legendFormat": "{{instance}} {{disk}}" }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Connections: open & accepts/s",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [ { "matcher": { "id": "byName", "options": "accepts/s" }, "properties": [ { "id": "unit", "value": "ops" }, { "id": "custom.axisPlacement", "value": "right" } ] }, { "matcher": { "id": "byName", "options": "open" }, "properties": [ { "id": "unit", "value": "short" } ] } ] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum(dfkv_open_connections{instance=~\"$node\"})", "legendFormat": "open" },
        { "refId": "B", "expr": "sum(rate(dfkv_accepts_total{instance=~\"$node\"}[$__rate_interval]))", "legendFormat": "accepts/s" }
      ]
    },
    {
      "id": 13,
      "type": "table",
      "title": "Cache node inventory (version / uptime)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 29 },
      "fieldConfig": { "defaults": {}, "overrides": [ { "matcher": { "id": "byName", "options": "uptime" }, "properties": [ { "id": "unit", "value": "s" } ] } ] },
      "options": { "showHeader": true },
      "targets": [
        { "refId": "A", "expr": "dfkv_build_info{job=\"dfkv_server\"}", "instant": true, "format": "table" },
        { "refId": "B", "expr": "dfkv_uptime_seconds{instance=~\"$node\"}", "instant": true, "format": "table" }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "job": true }, "renameByName": { "Value #A": "build", "Value #B": "uptime" } } }
      ]
    },
    {
      "id": 200,
      "type": "row",
      "title": "RDMA",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 37 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 20,
      "type": "stat",
      "title": "RDMA active connections",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 38 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        { "refId": "A", "expr": "sum(dfkv_rdma_active_conns{instance=~\"$node\"})", "instant": true }
      ]
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "RDMA completions/s & errors/s",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 38 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [ { "matcher": { "id": "byName", "options": "errors/s" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] } ] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(dfkv_rdma_completions_total{instance=~\"$node\"}[$__rate_interval]))", "legendFormat": "completions/s" },
        { "refId": "B", "expr": "sum(rate(dfkv_rdma_completion_errors_total{instance=~\"$node\"}[$__rate_interval]))", "legendFormat": "errors/s" }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "RDMA idle reclaims/s",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 38 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(dfkv_rdma_idle_reclaims_total{instance=~\"$node\"}[$__rate_interval]))", "legendFormat": "idle reclaims/s" }
      ]
    },
    {
      "id": 300,
      "type": "row",
      "title": "MDS (dfkv_mds — Prometheus pull /metrics)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 46 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 30,
      "type": "stat",
      "title": "MDS members (last list)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 47 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "targets": [
        { "refId": "A", "expr": "max(dfkv_mds_members)", "instant": true }
      ]
    },
    {
      "id": 31,
      "type": "stat",
      "title": "MDS requests/s (total)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 47 },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(dfkv_mds_register_requests_total[$__rate_interval])) + sum(rate(dfkv_mds_keepalives_total[$__rate_interval])) + sum(rate(dfkv_mds_list_requests_total[$__rate_interval]))" }
      ]
    },
    {
      "id": 32,
      "type": "stat",
      "title": "etcd errors/s",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 47 },
      "fieldConfig": { "defaults": { "unit": "ops", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 0.001 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(dfkv_mds_etcd_errors_total[$__rate_interval]))" }
      ]
    },
    {
      "id": 33,
      "type": "timeseries",
      "title": "MDS ops/s (register / keepalive / list)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 51 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(dfkv_mds_register_requests_total[$__rate_interval]))", "legendFormat": "register" },
        { "refId": "B", "expr": "sum(rate(dfkv_mds_keepalives_total[$__rate_interval]))", "legendFormat": "keepalive" },
        { "refId": "C", "expr": "sum(rate(dfkv_mds_list_requests_total[$__rate_interval]))", "legendFormat": "list" }
      ]
    },
    {
      "id": 34,
      "type": "timeseries",
      "title": "etcd: lease grants/s & errors/s",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 51 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [ { "matcher": { "id": "byName", "options": "etcd errors/s" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] } ] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(dfkv_mds_lease_grants_total[$__rate_interval]))", "legendFormat": "lease grants/s" },
        { "refId": "B", "expr": "sum(rate(dfkv_mds_etcd_errors_total[$__rate_interval]))", "legendFormat": "etcd errors/s" }
      ]
    },
    {
      "id": 35,
      "type": "table",
      "title": "MDS replica inventory (version per instance)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 59 },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true },
      "targets": [
        { "refId": "A", "expr": "dfkv_build_info{role=\"mds\"}", "instant": true, "format": "table" }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "Value": true, "__name__": true, "job": true } } }
      ]
    }
  ]
}
