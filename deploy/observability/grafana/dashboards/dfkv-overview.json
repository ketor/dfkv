{
  "uid": "dfkv-overview",
  "title": "dfkv — cluster overview",
  "tags": ["dfkv", "telemetry"],
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "type": "query",
        "name": "connector_type",
        "label": "Connector type",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "qryType": 1, "query": "label_values(dfkv_connector_info, dfkv_connector_type)", "refId": "A" },
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2,
        "sort": 1
      },
      {
        "type": "query",
        "name": "connector_id",
        "label": "Connector id",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "qryType": 1, "query": "label_values(dfkv_connector_info{dfkv_connector_type=~\"$connector_type\"}, dfkv_connector_id)", "refId": "A" },
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Connector instances",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "targets": [
        { "refId": "A", "expr": "count(dfkv_connector_info{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"})", "instant": true }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Success rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.95 }, { "color": "green", "value": 0.99 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(dfkv_connector_ops_total{status=\"ok\", dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}[$__rate_interval])) / clamp_min(sum(rate(dfkv_connector_ops_total{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}[$__rate_interval])), 1e-9)", "instant": true }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "PUT req/s",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(dfkv_connector_ops_total{op=\"put\", dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}[$__rate_interval]))" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "GET req/s",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(dfkv_connector_ops_total{op=\"get\", dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}[$__rate_interval]))" }
      ]
    },
    {
      "id": 5,
      "type": "bargauge",
      "title": "Instances by type",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient" },
      "targets": [
        { "refId": "A", "expr": "count by (dfkv_connector_type) (dfkv_connector_info{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"})", "instant": true, "legendFormat": "{{dfkv_connector_type}}" }
      ]
    },
    {
      "id": 6,
      "type": "table",
      "title": "Connector inventory",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true },
      "targets": [
        { "refId": "A", "expr": "dfkv_connector_info{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}", "instant": true, "format": "table" }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "Value": true, "__name__": true, "job": true, "otel_scope_name": true, "otel_scope_version": true, "otel_scope_schema_url": true, "service_name": true, "service_namespace": true, "telemetry_sdk_language": true, "telemetry_sdk_name": true, "telemetry_sdk_version": true } } }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Requests by op",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum by (op) (rate(dfkv_connector_ops_total{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}[$__rate_interval]))", "legendFormat": "{{op}}" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Ops by status (success / fail)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal" } } }, "overrides": [ { "matcher": { "id": "byName", "options": "fail" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] }, { "matcher": { "id": "byName", "options": "ok" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ] } ] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum by (status) (rate(dfkv_connector_ops_total{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}[$__rate_interval]))", "legendFormat": "{{status}}" }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Keys/s by op",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum by (op) (rate(dfkv_connector_keys_total{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}[$__rate_interval]))", "legendFormat": "{{op}}" }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Throughput by op (bytes/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum by (op) (rate(dfkv_connector_bytes_total{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}[$__rate_interval]))", "legendFormat": "{{op}}" }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Op latency (avg / p99) by op",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 0 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum by (op) (rate(dfkv_connector_op_seconds_sum{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}[$__rate_interval])) / clamp_min(sum by (op) (rate(dfkv_connector_op_seconds_count{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}[$__rate_interval])), 1e-9)", "legendFormat": "avg {{op}}" },
        { "refId": "B", "expr": "histogram_quantile(0.99, sum by (le, op) (rate(dfkv_connector_op_seconds_bucket{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"}[$__rate_interval])))", "legendFormat": "p99 {{op}}" }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Max op latency by op",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 0 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "max by (op) (dfkv_connector_op_max_seconds{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"})", "legendFormat": "max {{op}}" }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Per-cache-node latency (avg / max) — client per-peer probe (enable with DFKV_PROBE_INTERVAL_MS)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 0 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "avg by (peer) (dfkv_client_peer_latency_avg_seconds{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"})", "legendFormat": "avg {{peer}}" },
        { "refId": "B", "expr": "max by (peer) (dfkv_client_peer_latency_max_seconds{dfkv_connector_type=~\"$connector_type\", dfkv_connector_id=~\"$connector_id\"})", "legendFormat": "max {{peer}}" }
      ]
    }
  ]
}
